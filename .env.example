# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Serveur Node.js
NODE_ENV=production
PORT=3000

# URL publique du site
NEXT_PUBLIC_SITE_URL=https://www.frtp.fr

# Email de notification des demandes de contact
CONTACT_MAIL_TO=contact@frtp.fr
CONTACT_MAIL_FROM=contact@frtp.fr

# SMTP OVH pour l'envoi des notifications
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@frtp.fr
SMTP_PASSWORD=
